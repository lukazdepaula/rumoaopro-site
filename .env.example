NEXT_PUBLIC_CONTACT_EMAIL=contato@rumoaopro.com.br
NEXT_PUBLIC_SHOPIFY_URL=https://www.rumoaopro.com.br
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Public legal identity displayed in Terms, Privacy and Refund pages.
NEXT_PUBLIC_LEGAL_NAME=RumoAoPro
NEXT_PUBLIC_LEGAL_DOCUMENT=
NEXT_PUBLIC_LEGAL_ADDRESS=

# Checkout database/storage
CHECKOUT_GATEWAY_MODE=mock
CHECKOUT_DB_DRIVER=sqlite
CHECKOUT_DB_PATH=.data/rumoaopro.sqlite
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PRIVATE_FILES_DIR=private-files
SIGNED_DOWNLOAD_SECRET=change-me-download-secret
USD_TO_BRL_RATE=5.50

# Admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_SESSION_SECRET=change-me-admin-session-secret
ADMIN_LOGIN_EMAILS=admin@example.com
ADMIN_EMAILS=admin@example.com

# Customer account
CUSTOMER_SESSION_SECRET=change-me-customer-session-secret

# Mercado Pago Pix
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-mercado-pago-access-token
MERCADO_PAGO_WEBHOOK_SECRET=

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Email delivery
EMAIL_PROVIDER=mock
EMAIL_FROM=RumoAoPro <no-reply@rumoaopro.com>
INTERNAL_SALES_EMAIL=contato@rumoaopro.com.br
EMAIL_PROVIDER_API_KEY=
RESEND_API_KEY=

# Product prices. Adjust before production.
RAP_PROGRAM_PRICE_USD=38.95
RAP_PROGRAM_PRICE_BRL=199
